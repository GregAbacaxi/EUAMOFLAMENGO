void drawFlamengo() {
  display.clear();
  display.drawXbm(32, 0, 64, 64, flamengoLogo);
  display.display();
  delay(4000); 
  display.clear();
}

void printBuffer() {
  const char* hino[] = {
    "Uma vez Flamengo,",
    "Sempre Flamengo",
    "Flamengo sempre",
    "eu hei de ser",
    "É meu maior prazer",
    "Vê-lo brilhar",
    "Seja na terra,",
    "seja no mar",
    "Vencer, vencer, vencer",
    "Uma vez Flamengo,",
    "Flamengo ate morrer"
  };
  uint8_t linhas = sizeof(hino) / sizeof(hino[0]);

  display.clear();
  for (uint8_t i = 0; i < linhas; i++) {
    display.println(hino[i]);
    delay(1000);
  }
  display.display();
}

void setup() {
  display.init();
  display.flipScreenVertically();
  display.setContrast(255);
  //e8rtp::setup(buzzer, 5, (char*)hinoRTTTL);  // 
  //e8rtp::start();
}

void loop() {

  printBuffer();
  delay(1000);
  display.clear();

  drawFlamengo();
  delay(1000);
  display.clear();
  //e8rtp::loop(); 

}